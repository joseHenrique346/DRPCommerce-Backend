{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "rota_store": {
        "ClusterId": "cluster_store",
        "Match": {
          "Path": "/api/store/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/store" }
        ]
      },
      "rota_drop": {
        "ClusterId": "cluster_drop",
        "Match": {
          "Path": "/api/drop/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/drop" }
        ]
      }
    },
    "Clusters": {
      "cluster_store": {
        "Destinations": {
          "destino_principal": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "cluster_drop": {
        "Destinations": {
          "destino_principal": {
            "Address": "http://localhost:5002"
          }
        }
      }
    }
  }
}